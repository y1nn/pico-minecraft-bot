# Telegram Bot Token
BOT_TOKEN=123456:telegram_bot_token

# Allowed Chat IDs (Comma separated)
ALLOWED_CHAT_IDS=123456789

# Owner ID (For sensitive commands like OP)
OWNER_ID=123456789

# Docker Container Name
CONTAINER_NAME=minecraft

# Paths
PROPERTIES_FILE=/home/user/minecraft/data/server.properties
BACKUP_SCRIPT=/home/user/minecraft/scripts/auto_backup.sh

# Docker Compose file used by monitor_logs: docker compose -f <COMPOSE_FILE> logs ...
COMPOSE_FILE=docker-compose.yml
